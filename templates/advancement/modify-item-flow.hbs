<div>
    <div class="items-section card">
        <div class="items-header header">
            <h4 class="item-name">{{ localize "DND5E.ADVANCEMENT.ModifyItem.FIELDS.changes.label" }}</h4>
        </div>
        <ul class="item-list unlist">
            {{#each changes}}
            <li class="item flexrow" data-uuid="{{ enchantment.uuid }}">
                <div class="item-row">
                    <div class="item-name flexrow" data-action="viewItem">
                        {{ dnd5e-icon enchantment.img alt=enchantment.name classes="gold-icon" }}
                        <div class="name-stacked">
                            <div class="title">{{ enchantment.name }}</div>
                        </div>
                    </div>
                </div>
                <div class="linked-items">
                    <ol class="unlist">
                        {{#each items}}
                        <li class="item-row" data-uuid="{{ uuid }}">
                            <div class="item-name" data-action="viewItem">
                                {{ dnd5e-icon img alt=name classes="gold-icon" }}
                                <div class="name-stacked">
                                    <div class="title">{{ name }}</div>
                                </div>
                            </div>
                        </li>
                        {{/each}}
                    </ol>
                </div>
            </li>
            {{/each}}
        </ul>
    </div>
</div>
